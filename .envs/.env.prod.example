# ─── PRODUÇÃO ────────────────────────────────────────────────────────────────
# Usado com: docker-compose.prod.yml
# NUNCA commitar este arquivo com valores reais!
# Copie para .env.prod e preencha os valores reais
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=CHANGE-ME-production-secret-key-must-be-at-least-50-random-characters

# PostgreSQL
DB_NAME=tickettche_prod
DB_USER=tickettche_prod
DB_PASSWORD=CHANGE-ME-very-strong-password-min-32-chars
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=require

# Redis (com senha forte)
REDIS_PASSWORD=CHANGE-ME-very-strong-redis-password
REDIS_URL=redis://:CHANGE-ME-very-strong-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE-ME-very-strong-redis-password@redis:6379/1

# Django
DEBUG=False
ALLOWED_HOSTS=tickettche.com,www.tickettche.com

# CORS
CORS_ALLOWED_ORIGINS=https://tickettche.com,https://www.tickettche.com

# Email (use serviço transacional: SendGrid, SES, Mailgun, etc.)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=CHANGE-ME-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@tickettche.com

# Uploads
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
