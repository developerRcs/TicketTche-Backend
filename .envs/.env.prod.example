# ─── PRODUÇÃO ────────────────────────────────────────────────────────────────
# Usado com: docker-compose.prod.yml
# NUNCA commitar este arquivo com valores reais!
# Copie para .env.prod e preencha os valores reais
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=CHANGE-ME-production-secret-key-must-be-at-least-50-random-characters

# PostgreSQL
DB_NAME=tickettche_prod
DB_USER=tickettche_prod
DB_PASSWORD=CHANGE-ME-very-strong-password-min-32-chars
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=require

# Redis (com senha forte)
REDIS_PASSWORD=CHANGE-ME-very-strong-redis-password
REDIS_URL=redis://:CHANGE-ME-very-strong-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE-ME-very-strong-redis-password@redis:6379/1

# Django
DEBUG=False
ALLOWED_HOSTS=tickettche.com,www.tickettche.com

# CORS
CORS_ALLOWED_ORIGINS=https://tickettche.com,https://www.tickettche.com

# Email (use serviço transacional: SendGrid, SES, Mailgun, etc.)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=CHANGE-ME-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@tickettche.com

# Uploads (local — usado apenas em dev/staging sem R2)
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# Cloudflare R2 (storage de arquivos — avatars, logos, eventos, QR codes)
# Crie em: https://dash.cloudflare.com → R2 → Create bucket
# Token em: R2 → Manage R2 API Tokens → Object Read & Write
R2_ACCOUNT_ID=CHANGE-ME-id-da-conta-cloudflare
R2_ACCESS_KEY_ID=CHANGE-ME-access-key-r2
R2_SECRET_ACCESS_KEY=CHANGE-ME-secret-key-r2
R2_BUCKET_NAME=tickettche-media
# URL pública: ative em R2 → bucket → Settings → Public Access
R2_PUBLIC_URL=CHANGE-ME-https://pub-xxxx.r2.dev

# MercadoPago
MP_ACCESS_TOKEN=CHANGE-ME-access-token-producao
MP_PUBLIC_KEY=CHANGE-ME-public-key-producao
MP_WEBHOOK_SECRET=CHANGE-ME-webhook-secret-64-hex
PAYMENT_GATEWAY_CLASS=apps.payments.providers.mercadopago_provider.MercadoPagoGateway
