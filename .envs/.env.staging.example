# ─── STAGING / HOMOLOGAÇÃO ───────────────────────────────────────────────────
# Usado com: docker-compose.staging.yml
# Copie para .env.staging e preencha os valores reais
DJANGO_SETTINGS_MODULE=config.settings.staging
SECRET_KEY=CHANGE-ME-staging-secret-key-min-50-chars

# PostgreSQL
DB_NAME=tickettche_staging
DB_USER=tickettche_staging
DB_PASSWORD=CHANGE-ME-strong-password
DB_HOST=db
DB_PORT=5432
DB_SSLMODE=prefer

# Redis (com senha)
REDIS_PASSWORD=CHANGE-ME-redis-password
REDIS_URL=redis://:CHANGE-ME-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:CHANGE-ME-redis-password@redis:6379/1

# Django
DEBUG=False
ALLOWED_HOSTS=staging.tickettche.com,www.staging.tickettche.com

# CORS
CORS_ALLOWED_ORIGINS=https://staging.tickettche.com

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE-ME@gmail.com
EMAIL_HOST_PASSWORD=CHANGE-ME-app-password
DEFAULT_FROM_EMAIL=noreply@staging.tickettche.com

# Uploads
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
