# Copie o arquivo adequado de .envs/ para a raiz:
#   Local:    cp .envs/.env.local .env
#   Staging:  cp .envs/.env.staging.example .envs/.env.staging  (preencha os valores)
#   Prod:     cp .envs/.env.prod.example .envs/.env.prod         (preencha os valores)
DJANGO_SETTINGS_MODULE=config.settings.local
